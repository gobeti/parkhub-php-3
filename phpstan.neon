includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/

    # Level 2 with baseline. Raised from 1 after the strict_types migration
    # closed; level 2 adds "unknown methods on all types (including $this)"
    # which is where Larastan's dynamic-property checks kick in.
    level: 2

    # Exclude generated/cache files
    excludePaths:
        - storage/
        - bootstrap/cache/
        - vendor/

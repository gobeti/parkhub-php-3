includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/

    # Level 1 with baseline. Raised from 0 after the declare(strict_types=1)
    # migration landed across all 171 app/ files — increase further as
    # baseline errors are resolved.
    level: 1

    # Exclude generated/cache files
    excludePaths:
        - storage/
        - bootstrap/cache/
        - vendor/

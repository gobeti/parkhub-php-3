{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["php", "nodejs"],
      "phases": {
        "setup": {
          "nixPkgs": ["php83", "nodejs_20"]
        },
        "build": {
          "cmds": [
            "composer install --no-interaction --prefer-dist --optimize-autoloader --no-dev",
            "npm ci",
            "npm run build"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT:-8080}",
    "preDeployCommand": "php artisan config:clear && php artisan cache:clear && php artisan optimize && php artisan migrate --force --no-interaction || true"
  }
}
